  "compilation_steps": {
    "step_1_dll": {
      "description": "Compile native DLL for license validation",
      "toolchain": "Visual Studio 2022 (x64 Native Tools)",
      "commands": [
        "cd agents/mt5",
        "cl.exe /LD /O2 /MT /EHsc /DUNICODE /D_UNICODE HedgeEdgeLicense.cpp /link /DEF:HedgeEdgeLicense.def /OUT:HedgeEdgeLicense.dll"
      ],
      "dependencies": [
        "WinHTTP.lib - For HTTPS requests",
        "Windows SDK - Standard libraries"
      ],
      "output": "HedgeEdgeLicense.dll (x64)"
    },
    "step_2_copy_dlls": {
      "description": "Copy DLLs to MT5 Libraries folder",
      "target_path": "%APPDATA%/MetaQuotes/Terminal/<TERMINAL_ID>/MQL5/Libraries/",
      "files_to_copy": [
        "HedgeEdgeLicense.dll",
        "libzmq.dll (from agents/mt5/lib/)",
        "libsodium.dll (from agents/mt5/lib/)"
      ]
    },
    "step_3_compile_ea": {
      "description": "Compile EA in MetaEditor",
      "steps": [
        "Open MetaEditor (F4 in MT5 terminal)",
        "Open agents/mt5/HedgeEdgeLicense.mq5",
        "Press F7 (Compile)",
        "Verify no errors in compilation log"
      ],
      "output": "HedgeEdgeLicense.ex5 in MQL5/Experts/"
    }
  },
  
  "mt5_terminal_configuration": {
    "allow_dll_imports": {
      "path": "Tools > Options > Expert Advisors",
      "settings": [
        "Allow DLL imports: ENABLED",
        "Allow WebRequest for listed URLs: ENABLED"
      ]
    },
    "webrequest_whitelist": {
      "path": "Tools > Options > Expert Advisors",
      "urls_to_add": [
        "https://api.hedge-edge.com",
        "http://localhost:8080 (for development)"
      ]
    },
    "auto_trading": {
      "description": "Enable AutoTrading button in toolbar"
    }
  },
  
