{
  "task_id": "MT4-001",
  "title": "Develop MT4 Expert Advisor with 32-bit DLL",
  "assigned_to": "MT4 Specialist",
  "priority": "MEDIUM",
  "phase": 4,
  "estimated_hours": 8,
  "status": "NOT_STARTED",
  "depends_on": ["MT5-001"],
  
  "description": "Port the MT5 HedgeEdgeLicense EA to MT4 platform. MT4 requires a 32-bit DLL and has MQL4 syntax differences from MQL5.",
  
  "mt4_vs_mt5_differences": {
    "architecture": {
      "mt4": "32-bit only (x86)",
      "mt5": "64-bit (x64)"
    },
    "language": {
      "mt4": "MQL4",
      "mt5": "MQL5"
    },
    "order_system": {
      "mt4": "Order-based (OrderSend, OrderClose)",
      "mt5": "Position-based (PositionSelect, PositionGetDouble)"
    },
    "dll_calling": {
      "mt4": "Similar to MT5 but 32-bit",
      "mt5": "__stdcall convention, 64-bit"
    }
  },
  
  "source_files_to_create": [
    {
      "path": "agents/mt4/HedgeEdgeLicense.mq4",
      "description": "Main EA for MT4 (port from MT5)",
      "estimated_lines": 700
    },
    {
      "path": "agents/mt4/HedgeEdgeLicense32.cpp",
      "description": "32-bit native DLL source",
      "estimated_lines": 400
    },
    {
      "path": "agents/mt4/HedgeEdgeLicense32.h",
      "description": "DLL header file",
      "estimated_lines": 50
    },
    {
      "path": "agents/mt4/HedgeEdgeLicense32.def",
      "description": "Module definition for 32-bit exports",
      "estimated_lines": 15
    }
  ],
  
  "mql4_porting_guide": {
    "position_tracking": {
      "mt5_code": "PositionSelect(symbol); double profit = PositionGetDouble(POSITION_PROFIT);",
      "mt4_code": "OrderSelect(i, SELECT_BY_POS); double profit = OrderProfit();"
    },
    "order_iteration": {
      "mt5_code": "for(int i=0; i<PositionsTotal(); i++) { PositionGetTicket(i); }",
      "mt4_code": "for(int i=0; i<OrdersTotal(); i++) { OrderSelect(i, SELECT_BY_POS, MODE_TRADES); }"
    },
    "account_info": {
      "mt5_code": "AccountInfoDouble(ACCOUNT_BALANCE)",
      "mt4_code": "AccountBalance()"
    },
    "string_handling": {
      "note": "MQL4 string functions are similar but some differ in behavior"
    }
  },
  
  "dll_compilation_32bit": {
    "toolchain": "Visual Studio 2022 (x86 Native Tools - 32-bit)",
    "commands": [
      "call \"C:\\Program Files\\Microsoft Visual Studio\\2022\\Community\\VC\\Auxiliary\\Build\\vcvars32.bat\"",
      "cl.exe /LD /O2 /MT /EHsc /DUNICODE /D_UNICODE HedgeEdgeLicense32.cpp /link /DEF:HedgeEdgeLicense32.def /OUT:HedgeEdgeLicense32.dll"
    ],
    "output": "HedgeEdgeLicense32.dll (x86, 32-bit)",
    "dependencies": [
      "WinHTTP.lib (32-bit)",
      "Windows SDK (32-bit components)"
    ]
  },
  
  "zmq_for_mt4": {
    "status": "Optional - can use file-based IPC initially",
    "notes": [
      "32-bit libzmq.dll required",
      "Download from zeromq.org or build from source",
      "Alternative: Use file-based channel like MT5 fallback mode"
    ],
    "recommendation": "Start with file-based IPC, add ZMQ later if needed"
  },
  
  "file_based_ipc": {
    "data_file": "%APPDATA%/HedgeEdge/mt4_channel.json",
    "command_file": "%APPDATA%/HedgeEdge/mt4_commands.json",
    "format": "Same JSON format as MT5 file-based channel",
    "polling_interval": "100ms"
  },
  
