  "ctrader_requirements": {
    "platform": "cTrader Desktop (version 4.x+)",
    "permissions": "FullAccess (for HTTP and Named Pipes)",
    "dotnet": ".NET 6.0+ (included with cTrader)"
  },
  
  "compilation_steps": {
    "step_1_open_ctrader": {
      "description": "Open cTrader and access Automate section",
      "steps": [
        "Launch cTrader Desktop",
        "Click on 'Automate' tab in bottom panel",
        "Click 'New cBot' or 'Open cBot Source'"
      ]
    },
    "step_2_create_cbot": {
      "description": "Create new cBot project",
      "steps": [
        "Right-click on 'cBots' > 'New cBot'",
        "Name: HedgeEdgeLicense",
        "Replace generated code with content from agents/ctrader/HedgeEdgeLicense.cs"
      ]
    },
    "step_3_build": {
      "description": "Build the cBot",
      "steps": [
        "Click 'Build' button or press Ctrl+B",
        "Check Build Output for errors",
        "Ensure 'Build Succeeded' message appears"
      ],
      "expected_output": "HedgeEdgeLicense.algo in cTrader's algo folder"
    },
    "step_4_set_permissions": {
      "description": "Configure cBot permissions",
      "path": "cBot Settings",
      "permissions": [
        "AccessRights = FullAccess (required for HTTP calls)"
      ]
    }
  },
  
  "cbot_parameters": {
    "License": {
      "LicenseKey": {
        "type": "string",
        "required": true,
        "description": "Your Hedge Edge license key"
      },
      "DeviceId": {
        "type": "string",
        "default": "auto-generated",
        "description": "Unique device identifier"
      },
      "EndpointUrl": {
        "type": "string",
        "default": "https://api.hedge-edge.com/v1/license/validate",
        "description": "License validation API endpoint"
      },
      "PollIntervalSeconds": {
        "type": "int",
        "default": 600,
        "range": "60-3600",
        "description": "License revalidation interval"
      }
    },
    "Communication": {
      "StatusChannel": {
        "type": "string",
        "default": "HedgeEdgeCTrader",
        "description": "Named pipe channel for data streaming"
      },
      "EnableCommands": {
        "type": "bool",
        "default": true,
        "description": "Enable remote commands from desktop app"
      },
      "DataEmitIntervalSeconds": {
        "type": "int",
        "default": 1,
        "description": "Position data emission frequency"
      }
    }
  },
  
  "testing_procedure": {
    "test_1_compilation": {
      "description": "Verify cBot compiles without errors",
      "expected": "Build Succeeded message, no warnings about FullAccess"
    },
    "test_2_attach_to_chart": {
      "description": "Attach cBot to a chart",
      "steps": [
        "Open any symbol chart",
        "Drag HedgeEdgeLicense from cBots list to chart",
        "Or double-click to open parameter dialog"
      ]
    },
    "test_3_license_validation": {
      "description": "Test with valid license key",
      "inputs": {
        "LicenseKey": "TEST-1234-5678-DEMO"
      },
      "expected": "Green status text 'Licensed - Active' on chart"
    },
    "test_4_named_pipe_connection": {
      "description": "Test Named Pipe data streaming",
      "steps": [
        "Start Hedge Edge desktop app",
        "Attach cBot with valid license",
        "Verify data appears in Accounts panel"
      ],
      "expected": "Account balance, equity, and positions displayed"
    },
    "test_5_commands": {
      "description": "Test remote commands",
      "commands_to_test": [
        "PAUSE - Should show 'Paused' status",
        "RESUME - Should show 'Licensed - Active' status",
        "STATUS - Should return current state"
      ]
    }
  },
  
  "communication_protocol": {
    "data_channel": {
      "type": "Named Pipe",
      "name": "\\\\.\\pipe\\HedgeEdgeCTrader",
      "format": "JSON",
      "sample_payload": {
        "type": "ACCOUNT_UPDATE",
        "timestamp": "2026-02-01T12:00:00Z",
        "accountId": "12345678",
        "balance": 10000.00,
        "equity": 10250.50,
        "positions": []
      }
    },
    "command_channel": {
      "type": "Named Pipe",
      "name": "\\\\.\\pipe\\HedgeEdgeCTrader_Commands",
      "format": "JSON",
      "sample_command": {
        "action": "CLOSE_ALL",
        "timestamp": "2026-02-01T12:00:00Z"
      }
    }
  },
  
