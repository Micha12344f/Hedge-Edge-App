# MT5 VPS Server Configuration
# ==============================
# IMPORTANT: Change the API key to a secure random string!
# Generate one at: https://randomkeygen.com/ (use CodeIgniter Encryption Keys)

# Secure API Key (64 characters recommended)
MT5_API_KEY=CHANGE_THIS_TO_A_SECURE_64_CHARACTER_RANDOM_STRING_NOW

# MT5 Terminal Path (default installation)
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# Server Configuration (optional)
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000
