.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
session-logs/

# OS files
.DS_Store
Thumbs.db

# Electron
out/

# Build (front-end) — exclude outputs but keep electron-builder resources
build/*
!build/icon.*

# PyInstaller / standalone agent builds
standalone/
*.spec

# Test scripts
zmq_listener_test.mjs
zmq_test2.mjs

