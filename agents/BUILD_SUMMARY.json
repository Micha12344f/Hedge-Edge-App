  "api_contract": {
    "endpoint": "POST /v1/license/validate",
    "base_url": "https://api.hedge-edge.com",
    "request": {
      "licenseKey": "string (required)",
      "accountId": "string (required)",
      "broker": "string (required)",
      "deviceId": "string (required)",
      "platform": "string ('MT5' | 'cTrader')",
      "version": "string ('1.0.0')"
    },
    "response_success": {
      "valid": true,
      "token": "string (JWT)",
      "ttlSeconds": "int (default 900)",
      "message": "string",
      "plan": "string ('monthly')",
      "expiresAt": "ISO8601 datetime"
    },
    "response_failure": {
      "valid": false,
      "message": "string (error reason)"
    }
  },
  
  "data_schema": {
    "account_snapshot": {
      "timestamp": "ISO8601 datetime",
      "platform": "string ('MT5' | 'cTrader')",
      "accountId": "string",
      "broker": "string",
      "balance": "number",
      "equity": "number",
      "margin": "number",
      "freeMargin": "number",
      "marginLevel": "number",
      "floatingPnL": "number",
      "currency": "string",
      "leverage": "number",
      "status": "string",
      "isLicenseValid": "boolean",
      "isPaused": "boolean",
      "lastError": "string | null",
      "positions": "array<PositionData>"
    },
    "position_data": {
      "id": "string",
      "symbol": "string",
      "volume": "number",
      "volumeLots": "number",
      "side": "string ('BUY' | 'SELL')",
      "entryPrice": "number",
      "currentPrice": "number",
      "stopLoss": "number | null",
      "takeProfit": "number | null",
      "profit": "number",
      "swap": "number",
      "commission": "number",
      "openTime": "ISO8601 datetime",
      "comment": "string"
    }
  },
  
  "commands": [
    {"action": "PAUSE", "description": "Pause trading operations"},
    {"action": "RESUME", "description": "Resume trading operations"},
    {"action": "CLOSE_ALL", "description": "Market close all open positions"},
    {"action": "CLOSE_POSITION", "params": ["positionId"], "description": "Close specific position"},
    {"action": "STATUS", "description": "Query current agent status"}
  ],
  
